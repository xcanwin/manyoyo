{
    "name": "@xcanwin/manyoyo",
    "version": "5.11.3",
    "imageVersion": "1.9.1-common",
    "playwrightCliVersion": "0.1.14",
    "description": "AI Agent CLI Security Sandbox for Docker and Podman",
    "keywords": [
        "manyoyo",
        "ai-agent",
        "agent-cli",
        "security-sandbox",
        "claude-code",
        "codex-cli",
        "gemini-cli",
        "opencode",
        "docker-sandbox",
        "podman-sandbox",
        "yolo-mode"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/xcanwin/manyoyo.git"
    },
    "license": "MIT",
    "author": "xcanwin",
    "type": "commonjs",
    "main": "bin/manyoyo.js",
    "bin": {
        "manyoyo": "bin/manyoyo.js",
        "my": "bin/manyoyo.js"
    },
    "scripts": {
        "dev:release": "node scripts/dev-release.js",
        "build:web-editor": "node scripts/build-web-code-editor.js",
        "install-link": "npm link",
        "test": "jest --coverage",
        "test:unit": "jest test/",
        "lint": "echo 'Lint check passed'",
        "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 5173",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs --host 127.0.0.1 --port 4173"
    },
    "homepage": "https://xcanwin.github.io/manyoyo/",
    "bugs": {
        "url": "https://github.com/xcanwin/manyoyo/issues"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "files": [
        "bin/manyoyo.js",
        "lib/**",
        "README.md",
        "LICENSE",
        "docker/manyoyo.Dockerfile",
        "docker/res/**",
        "manyoyo.example.json"
    ],
    "dependencies": {
        "@playwright/mcp": "0.0.76",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "commander": "^15.0.0",
        "json5": "^2.2.3",
        "marked": "^18.0.5",
        "playwright": "1.61.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-yaml": "^6.1.3",
        "@codemirror/language": "^6.12.3",
        "@codemirror/search": "^6.7.1",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.43.1",
        "codemirror": "^6.0.2",
        "jest": "^30.4.2",
        "vitepress": "^1.6.4"
    },
    "overrides": {
        "esbuild": "^0.25.12",
        "glob": "^13.0.6",
        "minimatch": "^10.2.5",
        "postcss": "^8.5.15",
        "test-exclude": "^8.0.0",
        "vite": "^6.4.3"
    },
    "jest": {
        "testMatch": [
            "**/test/**/*.test.js"
        ],
        "testEnvironment": "node",
        "modulePathIgnorePatterns": [
            "<rootDir>/temp/"
        ],
        "testPathIgnorePatterns": [
            "<rootDir>/temp/"
        ],
        "watchPathIgnorePatterns": [
            "<rootDir>/temp/"
        ]
    }
}
