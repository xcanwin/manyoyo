{
    // MANYOYO 全局配置文件，保存到 ~/.manyoyo/manyoyo.json

    // 容器基础参数（覆盖型：命令行 > runs.<name> > 全局配置 > 默认值）
    "containerName": "my-dev",
    "hostPath": "/path/to/your/project",
    "containerPath": "/path/to/your/project",
    "imageName": "localhost/xcanwin/manyoyo",
    "imageVersion": "1.8.8-common",
    "containerMode": "common",

    // 容器启动环境（env 按 key 合并覆盖；其余数组参数会累加）
    // 仅支持绝对路径，如 /abs/path.env
    "envFile": [],
    "env": {
        "IS_SANDBOX": "1"
    },
    "volumes": [],
    "ports": ["8888:8888"],

    // 仅首次创建容器时执行一次（创建后、常规 shell 前）
    "first": {
        // 仅支持绝对路径，如 /abs/path.env
        "envFile": [],
        "env": {},
        "shellPrefix": "",
        "shell": "",
        "shellSuffix": ""
    },

    // 常规命令参数（覆盖型：命令行 > runs.<name> > 全局配置 > 默认值）
    "shellPrefix": "",
    "shell": "",
    "shellSuffix": "",
    "agentPromptCommand": "",
    "yolo": "",
    "quiet": ["tip", "cmd"],

    // 构建参数（数组累加）
    "imageBuildArgs": [],

    // 网页认证参数（覆盖型；支持环境变量兜底）
    // 优先级：命令行 > runs.<name> > 全局配置 > 环境变量 > 默认值
    "serverUser": "admin",
    "serverPass": "change-this-password",

    // 可选插件（manyoyo playwright / manyoyo plugin playwright）
    "plugins": {
        "playwright": {
            // mixed: 支持容器+宿主机；container: 仅容器；host: 仅宿主机
            "runtime": "mixed",
            // 启用场景（可按需裁剪）
            "enabledScenes": ["mcp-cont-headless", "mcp-cont-headed", "mcp-host-headless", "mcp-host-headed", "cli-host-headless", "cli-host-headed"],
            // my run 默认注入的 playwright-cli 宿主场景
            "cliSessionScene": "cli-host-headless",
            // mcp-add 默认 host（可改为 localhost / 127.0.0.1）
            "mcpDefaultHost": "host.docker.internal",
            // mcp-cont-headed 场景读取的密码环境变量名（默认 VNC_PASSWORD）
            "vncPasswordEnvKey": "VNC_PASSWORD",
            // playwright ext-download 的 CRX prodversion 参数
            "extensionProdversion": "132.0.0.0",
            // 注入 navigator.platform（默认与内置 UA 对齐为 MacIntel）
            "navigatorPlatform": "MacIntel",
            // 是否禁用 WebRTC（默认 false）
            "disableWebRTC": false,
            "ports": {
                "mcpContHeadless": 8931,
                "mcpContHeaded": 8932,
                "mcpHostHeadless": 8933,
                "mcpHostHeaded": 8934,
                "cliHostHeadless": 8935,
                "cliHostHeaded": 8936,
                "mcpContHeadedNoVnc": 6080
            }
        }
    },

    // 运行配置集合：通过 -r <name> 读取 runs.<name>
    "runs": {
        "claude": {
            "containerName": "my-claude-{now}",
            "env": {
                "ANTHROPIC_MODEL": "claude-sonnet-4-5"
            },
            "first": {
                "shell": "echo first-init"
            },
            "shell": "claude",
            "agentPromptCommand": "claude -p {prompt}",
            "yolo": "c",
            "plugins": {
                "playwright": {
                    "runtime": "container"
                }
            }
        }
    }
}
